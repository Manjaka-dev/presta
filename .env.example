# Base URL de votre boutique PrestaShop (sans /api).
# Laisser vide pour utiliser le proxy Vite sur /api.
VITE_PRESTA_BASE_URL=

# Forcer l'utilisation du proxy Vite en dev (true/false). Laisser vide pour auto-detection.
VITE_PRESTA_USE_PROXY=

# Cle API generee dans PrestaShop (service web)
VITE_PRESTA_API_KEY=your_api_key_here

